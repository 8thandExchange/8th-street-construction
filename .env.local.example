# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role key — SERVER ONLY, never expose. Used in API routes / admin actions.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend — for transactional email (lead notifications, booking confirmations)
# Sign up at resend.com, get an API key. Free tier: 100 emails/day, 3000/month.
RESEND_API_KEY=re_YOUR_KEY

# Email addresses
EMAIL_FROM="8th Street Construction <hello@8thstreetconstruction.com>"
EMAIL_TO_LEADS=construction@8thandexchange.com

# Public site URL — used in emails, sitemap, canonical tags
NEXT_PUBLIC_SITE_URL=https://8thstreetconstruction.com

# Stripe — card checkout in client portal (optional if using Mercury card pay)
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY

# Mercury — invoicing & ACH/card payments (requires Mercury Plus/Pro subscription)
# Generate API token at https://app.mercury.com/settings/tokens
# List accounts via GET /api/v1/accounts to find destination account ID
# Whitelist Fixie static IP(s) on the token when using Modify Invoices * scopes
MERCURY_API_TOKEN=secret-token:mercury_production_YOUR_TOKEN
MERCURY_DESTINATION_ACCOUNT_ID=YOUR_CHECKING_ACCOUNT_UUID
# Webhook secret from Mercury dashboard when registering https://yoursite.com/api/mercury/webhook
MERCURY_WEBHOOK_SECRET=whsec_YOUR_KEY

# Fixie — static outbound IP for Vercel (auto-set by Vercel Fixie integration)
# FIXIE_URL=http://fixie:password@velodrome.usefixie.com:80

# Cron — Vercel cron auth (same secret for all /api/cron/* routes)
CRON_SECRET=generate_a_long_random_string_here

# Share links — signs the password cookie for public /share/<token> progress pages.
# Optional: falls back to SUPABASE_SERVICE_ROLE_KEY if unset.
SHARE_LINK_SECRET=generate_a_long_random_string_here

# Anthropic (Claude) — powers AI drafting (client updates, etc.)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY
# Optional: override the model (defaults to a current Claude Sonnet alias)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Optional: model for the /admin/assistant chatbot (defaults to claude-opus-4-8)
# ANTHROPIC_ASSISTANT_MODEL=claude-opus-4-8

# GoHighLevel (LeadConnector) — SMS notifications to clients and yourself.
# Create a Private Integration token: GHL → Settings → Private Integrations
# (scopes: contacts.write, conversations/message.write). Location ID is in
# Settings → Business Profile. Leave unset to disable SMS (email still sends).
# GHL_API_TOKEN=pit-YOUR_TOKEN
# GHL_LOCATION_ID=YOUR_LOCATION_ID
# Your cell — receives texts when a client messages/approves something
# GHL_ADMIN_SMS_TO=+17065550123

# Revalidation secret — used to trigger ISR revalidation after admin edits
REVALIDATE_SECRET=generate_a_long_random_string_here

# Web push (PWA notifications) — generate once: npx web-push generate-vapid-keys
# Public key is also exposed to the browser via NEXT_PUBLIC_.
VAPID_PUBLIC_KEY=YOUR_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_PRIVATE_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_PUBLIC_KEY
