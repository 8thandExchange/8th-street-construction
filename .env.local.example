# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role key — SERVER ONLY, never expose. Used in API routes / admin actions.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend — for transactional email (lead notifications, booking confirmations)
# Sign up at resend.com, get an API key. Free tier: 100 emails/day, 3000/month.
RESEND_API_KEY=re_YOUR_KEY

# Email addresses
EMAIL_FROM="8th Street Construction <hello@8thstreetconstruction.com>"
EMAIL_TO_LEADS=construction@8thandexchange.com

# Public site URL — used in emails, sitemap, canonical tags
NEXT_PUBLIC_SITE_URL=https://8thstreetconstruction.com

# Revalidation secret — used to trigger ISR revalidation after admin edits
REVALIDATE_SECRET=generate_a_long_random_string_here
